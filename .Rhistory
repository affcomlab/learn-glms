## Load packages
library(tidyverse)
library(easystats)
library(ggeffects)
library(qqplotr)
library(ordinal)
## Read in data from file
gradapp <- read_csv("gradapp.csv")
gradapp
mytheme <- theme_bw(
base_size = 12
)
## Prepare the data for ordinal model
gradapp$apply <- factor(gradapp$apply,
levels = c("unlikely", "somewhat likely", "very likely"), #Must indicate order
ordered = TRUE)
gradapp #print
## Prepare the data for analysis
gradapp2 <-
gradapp |>
mutate(
gradapp_n = case_match(
apply,
"unlikely" ~ 1,
"somewhat likely" ~ 2,
"very likely" ~ 3
)
)
gradapp2 #print
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply)
) +
geom_boxplot()
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply, color = pared)
) +
geom_boxplot()
fitlm1 <- lm(
formula = gradapp_n ~ gpa + public,
data = gradapp2
)
model_parameters(fitlm1) |> print_md()
## check residuals
check_residuals(fitlm1) |> plot()
check_normality(fitlm1) |> plot()
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa + pared,
data = gradapp2,
link = "logit"
)
model_parameters(fit2)
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa + pared,
data = gradapp2,
link = "probit"
)
model_parameters(fit2)
