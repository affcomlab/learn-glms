# Simulate a dataset
set.seed(123)
data <- data.frame(
score = c(6, 7, 5, 8, 7),         # Bounded count data (e.g., test scores)
total = 10,                        # Upper bound for the count (max score = 10)
predictor = c(1, 2, 3, 4, 5)       # Some predictor variable (e.g., study hours)
)
# Fit the binomial regression model
# score is the number of successes, and total - score is the number of failures
model <- glm(cbind(score, total - score) ~ predictor, family = binomial, data = data)
# Show the summary of the model
summary(model)
View(data)
# Predict the probabilities of success for new data
new_data <- data.frame(predictor = c(6, 7))
predicted_probs <- predict(model, new_data, type = "response")
# Print predicted probabilities of success
predicted_probs
predict_response(model)
predict_response(model) |> plot()
6/10
View(new_data)
new_data <- data.frame(predictor = c(4, 7))
predicted_probs <- predict(model, new_data, type = "response")
# Print predicted probabilities of success
predicted_probs
predict_response(model)
predict_response(model)
predict_response(model) |> plot()
