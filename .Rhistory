install.packages("mice")
library(mice)
?ampute
# depression2 <-
#   depression |>
#   mutate(
#     phq9_max = 27, # maximum possible score (can be same or different per row)
#     phq9_p = phq9 / phq9_max # proportion of maximum possible score per row
#   )
depression2 <-
depression |>
mutate(
dcl_max = 9,
dcl_sum = rowSums(pick(dcl_1:dcl_9)),
dcl9_p = dcl_sum / dcl_max
)
depression2
depression3 <- ampute(data = depression2)
View(depression3)
depression3$amp
my_patterns <- depression3$patterns
my_patterns
depression3$amp
my_patterns[:,5:16] <- 0
my_patterns[,5:16] <- 0
my_patterns
my_patterns[,1:4] <-1
depression4 <- ampute(data = depression2, patterns = my_patterns)
depression4$amp
depression3 <- ampute(data = depression2)
my_patterns <- depression3$patterns
my_patterns[,1:4] <-1
depression4 <- ampute(data = depression2, patterns = my_patterns)
my_patterns
res <-depression4$amp
View(res)
write_csv(res, "depression_checklist_m.csv")
