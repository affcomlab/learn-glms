## Load packages
library(tidyverse)
library(easystats)
library(ggeffects)
library(ordinal)
## Read in data from file
gradapp <- read_csv("gradapp.csv")
gradapp
mytheme <- theme_bw(
base_size = 12
)
## Load packages
library(tidyverse)
library(easystats)
library(ggeffects)
library(ordinal)
## Read in data from file
gradapp <- read_csv("gradapp.csv")
gradapp
View(gradapp)
## Prepare the data for ordinal model
gradapp2 <-
gradapp |>
factor(apply, levels = "unlikely", "somewhat likely", "very likely")
## Prepare the data for ordinal model
factor(gradapp$apply,
levels = c("unlikely", "somewhat likely", "very likely"),
ordered = TRUE)
## Prepare the data for ordinal model
gradapp$apply <- factor(gradapp$apply,
levels = c("unlikely", "somewhat likely", "very likely"),
ordered = TRUE)
## Prepare the data for ordinal model
gradapp$apply <- factor(gradapp$apply,
levels = c("unlikely", "somewhat likely", "very likely"),
ordered = TRUE)
gradapp
## Prepare the data for analysis
gradapp2 <-
gradapp |>
mutate(
gradapp_n = case_match(
apply,
"unlikely" ~ 1,
"somewhat likely" ~ 2,
"very likely" ~ 3
)
)
gradapp2 #print
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply)
) +
facet_wrap(~pared, labeller = "label_both") +
geom_boxplot()
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply)
) + boxplot()
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply)
) +
geom_boxplot()
## Explore gpa-apply relationship by parental graduate education
ggplot(
data = gradapp2,
mapping = aes(x = gpa, y = apply, color = pared)
) +
geom_boxplot()
View(gradapp2)
fitlm1 <- lm(
formula = ordered_n ~ gpa + public,
data = gradapp2
)
fitlm1 <- lm(
formula = apply_n ~ gpa + public,
data = gradapp2
)
View(gradapp2)
fitlm1 <- lm(
formula = gradapp_n ~ gpa + public,
data = gradapp2
)
model_parameters(fitlm1) |> print_md()
predict_response(fitlm1, terms = "gpa")
predict_response(fitlm1, terms = "gpa") |> plot()
