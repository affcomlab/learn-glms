library(qqplotr)
library(ordinal)
## Read in data from file
gradapp <- read_csv("gradapp.csv")
gradapp
## check residuals
check_residuals(fitlm1)
## check residuals
check_residuals(fitlm1) |> plot()
check_normality(fitlm1) |> plot()
View(gradapp2)
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa * pared,
data = gradapp2,
link = "logit"
)
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa * pared,
data = gradapp2,
link = "logit"
)
model_paramters(fit2)
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa * pared,
data = gradapp2,
link = "logit"
)
model_parameters(fit2)
## Fit ordinal regression
fit2 <- clm(
formula = apply ~ gpa + pared,
data = gradapp2,
link = "logit"
)
model_parameters(fit2)
plot(predict_response(fit2, term = "gpa"))
plot(predict_expectation(fit2, term = "gpa"))
